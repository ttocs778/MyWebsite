---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rui (Scott) Tang – About">
	<section class="page">
		<div class="page-title-row">
			<div class="page-title-left">
				<h1>About</h1>
			</div>
			<p class="page-title-caption">just test</p>
		</div>
	</section>

	<style>
		.page {
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
		}

		h1 {
			margin: 0 0 0.25rem;
			font-size: 1.6rem;
			letter-spacing: 0.06em;
		}

		.page-title-row h1 {
			margin: 0;
			font-size:  2.8rem;
			text-transform: none;
		}

		p {
			margin: 0;
			font-size: 1.05rem;
			line-height: 1.7;
		}
	</style>
</Layout>

