---
import '@fontsource-variable/atkinson-hyperlegible-next';
import '@fontsource/maple-mono';

const { title = 'Scott Tang', showVideoBackground = false, videoSrc = '', showFooter = true } = Astro.props;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body id="top" class:list={[isHome && 'home-page']}>
		{showVideoBackground ? (
			<div class="video-bg">
				{videoSrc ? (
					<video class="video-bg-media" autoplay muted loop playsinline aria-hidden="true">
						<source src={videoSrc} type="video/mp4" />
					</video>
				) : (
					<div class="video-bg-placeholder" aria-hidden="true"></div>
				)}
				<div class="video-bg-glass" aria-hidden="true"></div>
			</div>
		) : (
			<div class="pixel-bg"></div>
		)}
		{isHome && (
		<header class="home-header">
			<div class="home-header-bar">
				<a href="/" class="home-header-name">
					<span class="home-header-mark" aria-hidden="true">RT</span>
					<span class="home-header-text">Scott Tang</span>
				</a>
				<nav class="home-header-nav" aria-label="Main navigation">
					<a href="/" class="home-header-link">
						<svg class="home-header-link-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
						Home
					</a>
					<a href="/portfolio" class="home-header-link">
						<svg class="home-header-link-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14 13-8.381 8.38a1 1 0 0 1-3.001-3L11 9.999"/><path d="M15.973 4.027A13 13 0 0 0 5.902 2.373c-1.398.342-1.092 2.158.277 2.601a19.9 19.9 0 0 1 5.822 3.024"/><path d="M16.001 11.999a19.9 19.9 0 0 1 3.024 5.824c.444 1.369 2.26 1.676 2.603.278A13 13 0 0 0 20 8.069"/><path d="M18.352 3.352a1.205 1.205 0 0 0-1.704 0l-5.296 5.296a1.205 1.205 0 0 0 0 1.704l2.296 2.296a1.205 1.205 0 0 0 1.704 0l5.296-5.296a1.205 1.205 0 0 0 0-1.704z"/></svg>
						Portfolio
					</a>
					<a href="/about" class="home-header-link">
						<svg class="home-header-link-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M15 12h.01"/><path d="M19.38 6.813A9 9 0 0 1 20.8 10.2a2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/><path d="M9 12h.01"/></svg>
						About
					</a>
					<a href="/notes" class="home-header-link">
						<svg class="home-header-link-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/><path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/><path d="M2 18h4"/><path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/></svg>
						Notes
					</a>
				</nav>
			</div>
		</header>
		)}
		<div class="page" class:list={[!isHome && 'page-no-header']}>
			<main class="content">
				<slot />
			</main>
			{showFooter && (
			<footer class="site-footer">
				<div class="footer-inner">
					<div class="footer-row footer-row-main">
						<a href="#top" class="footer-back">
							<svg class="footer-back-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m18 15-6-6-6 6"/></svg>
							Back to top
						</a>
						<nav class="footer-nav-row" aria-label="Footer navigation">
							<a href="/" class="footer-nav-link">
								<svg class="footer-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
								Home
							</a>
							<a href="/portfolio" class="footer-nav-link">
								<svg class="footer-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14 13-8.381 8.38a1 1 0 0 1-3.001-3L11 9.999"/><path d="M15.973 4.027A13 13 0 0 0 5.902 2.373c-1.398.342-1.092 2.158.277 2.601a19.9 19.9 0 0 1 5.822 3.024"/><path d="M16.001 11.999a19.9 19.9 0 0 1 3.024 5.824c.444 1.369 2.26 1.676 2.603.278A13 13 0 0 0 20 8.069"/><path d="M18.352 3.352a1.205 1.205 0 0 0-1.704 0l-5.296 5.296a1.205 1.205 0 0 0 0 1.704l2.296 2.296a1.205 1.205 0 0 0 1.704 0l5.296-5.296a1.205 1.205 0 0 0 0-1.704z"/></svg>
								Portfolio
							</a>
							<a href="/notes" class="footer-nav-link">
								<svg class="footer-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/><path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/><path d="M2 18h4"/><path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/></svg>
								Notes
							</a>
							<a href="/about" class="footer-nav-link">
								<svg class="footer-nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M15 12h.01"/><path d="M19.38 6.813A9 9 0 0 1 20.8 10.2a2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/><path d="M9 12h.01"/></svg>
								About
							</a>
						</nav>
						<div class="footer-contact-row">
							<a href="https://www.instagram.com/ruiscott_39/" target="_blank" rel="noopener noreferrer" class="footer-link-icon" aria-label="Instagram">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
							</a>
							<a href="https://github.com/ttocs778" target="_blank" rel="noopener noreferrer" class="footer-link-icon" aria-label="GitHub">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
							</a>
							<a href="https://www.linkedin.com/in/scott-tang-gl/" target="_blank" rel="noopener noreferrer" class="footer-link-icon" aria-label="LinkedIn">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
							</a>
						</div>
					</div>
					<p class="footer-quote">“All the promises at sundown, I meant them like the rest.”</p>
				</div>
			</footer>
			)}
		</div>
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		--bg: #0a0a0a;
		--bg-alt: #111111;
		--accent: #71717a;
		--accent-soft: rgba(113, 113, 122, 0.25);
		--text: #fafafa;
		--muted: #a1a1aa;
		--border-subtle: rgba(161, 161, 170, 0.3);
		--pixel-size: 32px;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Atkinson Hyperlegible Next Variable', system-ui, -apple-system,
			BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', sans-serif;
		background: #0a0a0a;
		color: var(--text);
	}

	body {
		overflow-y: auto;
	}

	.page {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		padding: 2.5rem 5rem 3rem;
	}

	body.home-page .page {
		min-height: 0;
		/* Vertical position of hero block: increase to move lower, decrease to move higher */
		padding-top: 9rem;
	}

	.pixel-bg {
		position: fixed;
		inset: 0;
		background: #0a0a0a;
		z-index: 0;
	}

	.video-bg {
		position: fixed;
		inset: 0;
		z-index: 0;
		overflow: hidden;
	}

	.video-bg-media,
	.video-bg-placeholder {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.video-bg-placeholder {
		background: #0a0a0a;
	}

	.video-bg-glass {
		position: absolute;
		inset: 0;
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		background: rgba(0, 0, 0, 0.45);
	}

	.home-header {
		position: fixed;
		top: 4rem;
		left: 0;
		right: 0;
		z-index: 50;
		display: flex;
		justify-content: center;
		padding: 0 1.75rem;
		max-width: 1280px;
		margin: 0 auto;
		pointer-events: none;
	}

	.home-header-bar {
		pointer-events: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: 65%;
		max-width: 70rem;
		padding: 1.25rem 2rem;
		border-radius: 22px;
		background: rgba(18, 18, 18, 0.9);
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow:
			0 14px 35px rgba(0, 0, 0, 0.4),
			0 0 20px rgba(255, 255, 255, 0.06),
			0 0 40px rgba(255, 255, 255, 0.04);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.home-header > * {
		pointer-events: auto;
	}

	.home-header-name {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		color: #fafafa;
		font-weight: 600;
		font-size: 1.25rem;
		letter-spacing: 0.02em;
		transition: color 0.2s, opacity 0.2s;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
	}

	.home-header-name:hover {
		color: #fff;
		opacity: 0.95;
	}

	.home-header-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.08);
		color: #fafafa;
		font-size: 0.85rem;
		letter-spacing: 0.06em;
	}

	.home-header-nav {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.home-header-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.5rem 0;
		color: rgba(255, 255, 255, 0.85);
		font-size: 1.05rem;
		font-weight: 500;
		text-decoration: none;
		transition: color 0.2s, opacity 0.2s;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
	}

	.home-header-link:hover {
		color: #fff;
	}

	.home-header-link-icon {
		width: 20px;
		height: 20px;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		white-space: nowrap;
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 10px;
		background: linear-gradient(135deg, #27272a, #18181b);
		color: #fafafa;
		font-weight: 600;
		font-size: 0.9rem;
		letter-spacing: 0.06em;
		border: 1px solid rgba(255, 255, 255, 0.1);
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
	}

	.brand-text {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.name {
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: none;
		color: #f9fafb;
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 1.75rem;
		font-size: 1rem;
		flex-shrink: 0;
		white-space: nowrap;
	}

	.nav-link {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.25rem 0;
		border-radius: 8px;
		color: #a1a1aa;
		text-decoration: none;
		text-transform: none;
		letter-spacing: 0.04em;
		border: 1px solid transparent;
		transition:
			color 160ms ease,
			background 160ms ease,
			border-color 160ms ease,
			transform 120ms ease;
		font-size: 0.9rem;
	}

	.nav-link-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		color: #d4d4d8;
	}

	.nav-link-icon svg {
		width: 100%;
		height: 100%;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.nav-link-label {
		font-size: 1.05rem;
		font-weight: 700;
	}

	.nav-link:hover {
		color: #fafafa;
		border-color: transparent;
		transform: translateY(-1px);
	}

	.content {
		flex: 1;
		max-width: 1280px;
		margin: 5.25rem auto 0;
		padding: 2.25rem 1.75rem 0;
		display: flex;
		align-items: flex-start;
		justify-content: center;
	}

	.page-no-header .content {
		margin-top: 0;
		padding-top: 0;
		justify-content: flex-start;
		/* Align content start with head bar's left edge (bar is 65% wide, centered) */
		padding-left: calc(1.75rem + 17.5% * (100% - 3.5rem));
	}

	/* Title row: same width as head/foot bar – left: icon/slash + title, right: caption (mimic reference) */
	/* :global() so these apply to slot content (portfolio, notes, about) */
	:global(.page-title-row) {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		flex-wrap: nowrap;
		gap: 2rem;
		/* Match footer row: 65% of (viewport - side padding), same as .footer-row-main */
		width: 48rem;
		max-width: 150rem;
		margin-bottom: 1rem;
	}

	:global(.page-title-left) {
		display: flex;
		flex-direction: column;
		gap: 0;
		align-items: flex-start;
		flex-shrink: 0;
	}

	:global(.page-title-eyebrow) {
		display: flex;
		align-items: flex-end;
		gap: 0.35rem;
		color: #a5b4fc;
		font-size: 0.9rem;
		letter-spacing: 0.04em;
		line-height: 1;
	}

	:global(.page-title-eyebrow svg) {
		/* Match title size (e.g. .page-title-row h1 font-size); change with your title */
		width: 2.8rem !important;
		height: 2.8rem !important;
		min-width: 2.8rem;
		min-height: 2.8rem;
		flex-shrink: 0;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	:global(.page-title-row h1) {
		margin: 0;
	}

	:global(.page-title-caption) {
		font-size: 0.95rem;
		color: rgba(255, 255, 255, 0.75);
		line-height: 1.5;
		max-width: 28em;
		flex-shrink: 0;
		align-self: flex-end;
		padding-bottom: 0.1em;
		min-width: 0;
	}

	.page.page-no-header {
		/* Same vertical start as head bar (top: 4rem) */
		padding-top: 4rem;
	}

	.site-footer {
		margin-top: auto;
		padding: 2rem 0 1.5rem;
		border-top: 1px dotted rgba(161, 161, 170, 0.4);
		width: 100%;
	}

	.footer-inner {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		align-items: flex-start;
	}

	.footer-row-main {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		width: 65%;
		max-width: 70rem;
		margin-inline: auto;
		padding: 2rem 0;
	}

	.footer-row-main .footer-contact-row {
		justify-self: end;
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.footer-row-main .footer-link-icon {
		font-size: 1rem;
		color: var(--muted);
		text-decoration: none;
	}

	.footer-nav-row {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.footer-row-main .footer-nav-row {
		justify-self: center;
	}

	.footer-nav-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 1.05rem;
		font-weight: 600;
		color: #d4d4d8;
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer-nav-link:hover {
		color: #fafafa;
	}

	.footer-nav-icon {
		width: 20px;
		height: 20px;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.footer-back {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 1.05rem;
		font-weight: 400;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer-back:hover {
		color: #fafafa;
	}

	.footer-back-icon {
		width: 20px;
		height: 20px;
		fill: none;
		stroke: currentColor;
		stroke-width: 1;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.footer-link-icon {
